{
  "name": "shopedoo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.15.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:backend": "ts-node --transpile-only backend/server.ts",
    "dev:mobile": "npm run start --prefix mobile",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "next build",
    "build:api": "tsc -p backend/tsconfig.json",
    "start": "next start",
    "start:api": "node backend/dist/server.js",
    "seed:stores": "npm run build:api && node backend/dist/scripts/seedTunisiaStores.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/uuid": "^11.0.0",
    "@vercel/analytics": "1.6.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.16.0",
    "mongoose": "^8.9.6",
    "multer": "^2.2.0",
    "next": "16.2.6",
    "postcss": "^8.5",
    "qrcode": "^1.5.4",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.8.0",
    "stripe": "^22.2.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.1.0",
    "@types/node": "^24",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.18.0",
    "concurrently": "^10.0.3",
    "socket.io": "4.7.2",
    "ts-node": "^10.9.2",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  }
}
